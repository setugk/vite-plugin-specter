{
  "name": "vite-plugin-specter",
  "version": "0.1.1",
  "description": "Dev-only element inspector overlay for Vite projects. Hover any element to see its styles, component name, and spacing — then copy to clipboard for AI assistants.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "extension"
  ],
  "scripts": {
    "build": "tsup && node scripts/build-client.mjs && node scripts/build-extension.mjs",
    "dev": "tsup --watch",
    "gen-icons": "node scripts/gen-icons.mjs",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vite": ">=4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0"
  },
  "keywords": [
    "vite",
    "plugin",
    "inspector",
    "devtools",
    "design",
    "css"
  ],
  "license": "MIT"
}
